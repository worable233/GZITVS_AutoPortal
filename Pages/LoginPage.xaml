<Page
    x:Class="AutoPortal.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="6">
            <TextBlock 
                Text="登录" 
                Style="{StaticResource TitleLargeTextBlockStyle}"
                FontWeight="Bold"/>
            <TextBlock 
                Text="请输入您的学号和密码" 
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="1">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="320"
                MaxWidth="450"
                Padding="24"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Spacing="16" HorizontalAlignment="Stretch">
                    <!-- 学号输入 -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="学号" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBox
                            x:Name="UsernameTextBox"
                            HorizontalAlignment="Stretch"
                            PlaceholderText="请输入您的学号"
                            InputScope="Digits"
                            IsSpellCheckEnabled="False"/>
                    </StackPanel>

                    <!-- 密码输入 -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="密码" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <PasswordBox
                            x:Name="PasswordBox"
                            HorizontalAlignment="Stretch"
                            PlaceholderText="请输入您的密码"
                            PasswordRevealMode="Peek"/>
                    </StackPanel>

                    <!-- 错误提示 -->
                    <TextBlock
                        x:Name="ErrorMessage"
                        Foreground="{ThemeResource SystemErrorTextColor}"
                        Visibility="Collapsed"
                        TextWrapping="Wrap"/>

                    <!-- 登录按钮 -->
                    <Grid>
                        <Button
                            x:Name="LoginButton"
                            Content="登录"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="44"
                            Click="LoginButton_Click"/>

                        <ProgressRing
                            x:Name="ProgressRing"
                            IsActive="False"
                            Visibility="Collapsed"
                            Width="22"
                            Height="22"
                            HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- 配置按钮 -->
                    <Button
                        Content="前往配置账号"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        Click="SaveConfigButton_Click"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
