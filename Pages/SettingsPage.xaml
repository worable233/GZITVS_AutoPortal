<Page
    x:Class="AutoPortal.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="using:AutoPortal.Services"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="6">
            <TextBlock 
                Text="设置" 
                Style="{StaticResource TitleLargeTextBlockStyle}"
                FontWeight="Bold"/>
            <TextBlock 
                Text="应用外观与行为设置" 
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16">
                <!-- 账号配置 -->
                <Border
                    Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE713;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="账号配置" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="学号" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBox
                                    x:Name="UsernameTextBox"
                                    PlaceholderText="请输入您的学号"
                                    InputScope="Digits"
                                    IsSpellCheckEnabled="False"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="密码（可选）" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <PasswordBox
                                    x:Name="PasswordBox"
                                    PlaceholderText="留空则不保存密码"
                                    PasswordRevealMode="Peek"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Portal 地址" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBox
                                    x:Name="PortalUrlTextBox"
                                    PlaceholderText="http://10.189.108.11/"
                                    Text="http://10.189.108.11/"/>
                            </StackPanel>

                            <ToggleSwitch
                                x:Name="AutoLoginCheckBox"
                                Header="启用自动登录"
                                OffContent="关闭"
                                OnContent="开启"/>

                            <Button
                                Content="保存配置"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Height="44"
                                Click="SaveButton_Click"/>
                            
                            <InfoBar x:Name="ConfigSuccessMessage" Severity="Success" IsOpen="False" Visibility="Collapsed"/>
                            <InfoBar x:Name="ConfigErrorMessage" Severity="Error" IsOpen="False" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 行为设置 -->
                <Border
                    Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE76C;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="行为" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="12">
                            <ToggleSwitch
                                x:Name="AutoStartCheckBox"
                                Header="开机自启动"
                                OffContent="关闭"
                                OnContent="开启"
                                Toggled="AutoStartCheckBox_Toggled"/>
                            <StackPanel Spacing="8">
                                <TextBlock Text="图表更新间隔（秒）" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ComboBox
                                    x:Name="ChartUpdateIntervalComboBox"
                                    SelectionChanged="ChartUpdateIntervalComboBox_SelectionChanged"
                                    HorizontalAlignment="Stretch">
                                    <x:String>1 秒</x:String>
                                    <x:String>2 秒</x:String>
                                    <x:String>3 秒</x:String>
                                    <x:String>5 秒</x:String>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 外观设置 -->
                <Border
                    Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE790;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="外观" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="主题" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ComboBox
                                    x:Name="ThemeComboBox"
                                    SelectionChanged="ThemeComboBox_SelectionChanged"
                                    HorizontalAlignment="Stretch">
                                    <x:String>跟随系统</x:String>
                                    <x:String>浅色</x:String>
                                    <x:String>深色</x:String>
                                </ComboBox>
                            </StackPanel>

                            <ToggleSwitch
                                x:Name="MicaEffectCheckBox"
                                Header="Mica 效果"
                                OffContent="关闭"
                                OnContent="开启"
                                Toggled="MicaEffectCheckBox_Toggled"/>

                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Mica 透明度" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="MicaOpacityTextBlock" Text="100%" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                </Grid>
                                <Slider
                                    x:Name="MicaOpacitySlider"
                                    Minimum="0.1"
                                    Maximum="1.0"
                                    StepFrequency="0.05"
                                    TickFrequency="0.05"
                                    SnapsTo="Ticks"
                                    ManipulationCompleted="MicaOpacitySlider_ManipulationCompleted"
                                    Header=""/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 数据管理 -->
                <Border
                    Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7F8;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="数据管理" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="10">
                            <Button Content="清理缓存" HorizontalAlignment="Stretch" Height="44" Click="ClearCacheButton_Click"/>
                            <Button Content="重置应用" HorizontalAlignment="Stretch" Height="44" Click="ResetButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 关于 -->
                <Border
                    Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="关于" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="6">
                            <TextBlock Text="AutoPortal" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind services:AppVersionService.Version, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            <HyperlinkButton
                                Content="检查更新"
                                NavigateUri="https://github.com/worable233/GZITVS_AutoPortal/releases"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
