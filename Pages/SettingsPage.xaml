<Page
    x:Class="AutoPortal.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20">
            <StackPanel MaxWidth="760" Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="应用外观与行为设置" Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>

                <Border
                    Padding="16"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="外观" Style="{StaticResource BaseTextBlockStyle}"/>
                        <ComboBox
                            x:Name="ThemeComboBox"
                            Header="主题"
                            SelectedIndex="0"
                            SelectionChanged="ThemeComboBox_SelectionChanged">
                            <x:String>跟随系统</x:String>
                            <x:String>浅色</x:String>
                            <x:String>深色</x:String>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="行为" Style="{StaticResource BaseTextBlockStyle}"/>
                        <ToggleSwitch
                            x:Name="AutoStartCheckBox"
                            Header="开机自启动"
                            OffContent="关闭"
                            OnContent="开启"
                            Toggled="AutoStartCheckBox_Toggled"/>
                        <ToggleSwitch
                            x:Name="MinimizeToTrayCheckBox"
                            Header="最小化到系统托盘"
                            OffContent="关闭"
                            OnContent="开启"
                            Toggled="MinimizeToTrayCheckBox_Toggled"/>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="数据管理" Style="{StaticResource BaseTextBlockStyle}"/>
                        <Button Content="清理缓存" Click="ClearCacheButton_Click"/>
                        <Button Content="重置应用" Click="ResetButton_Click"/>
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="关于" Style="{StaticResource BaseTextBlockStyle}"/>
                        <TextBlock Text="AutoPortal v1.0.2" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="校园网自动登录助手" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <HyperlinkButton
                            Content="检查更新"
                            NavigateUri="https://github.com/worable233/GZITVS_AutoPortal/releases"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
