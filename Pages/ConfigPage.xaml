<Page
    x:Class="AutoPortal.Pages.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock 
                Text="配置管理"
                Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock 
                Text="管理您的账号和系统配置"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Stretch">
                <StackPanel Spacing="8">
                    <TextBlock 
                        Text="账号配置"
                        Style="{StaticResource BaseTextBlockStyle}"/>

                    <TextBox 
                        x:Name="UsernameTextBox"
                        Header="学号"
                        PlaceholderText="请输入您的学号"
                        InputScope="Digits"
                        IsSpellCheckEnabled="False"
                        HorizontalAlignment="Stretch"/>

                    <PasswordBox 
                        x:Name="PasswordBox"
                        Header="密码（可选）"
                        PlaceholderText="留空则不保存密码"
                        PasswordRevealMode="Peek"
                        HorizontalAlignment="Stretch"/>

                    <TextBox 
                        x:Name="PortalUrlTextBox"
                        Header="Portal 地址"
                        PlaceholderText="http://10.189.108.11/"
                        Text="http://10.189.108.11/"
                        HorizontalAlignment="Stretch"/>

                    <CheckBox 
                        x:Name="AutoLoginCheckBox"
                        Content="启用自动登录"/>
                </StackPanel>

                <InfoBar 
                    x:Name="SuccessMessage"
                    Severity="Success"
                    IsOpen="True"
                    Visibility="Collapsed"/>

                <InfoBar 
                    x:Name="ErrorMessage"
                    Severity="Error"
                    IsOpen="True"
                    Visibility="Collapsed"/>

                <StackPanel Spacing="8" Orientation="Horizontal">
                    <Button 
                        Content="保存配置"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SaveButton_Click"/>

                    <Button 
                        Content="测试登录"
                        Click="TestButton_Click"/>

                    <Button 
                        Content="删除配置"
                        Click="DeleteButton_Click"/>
                </StackPanel>

                <Expander Header="配置说明" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="8" Padding="12">
                        <TextBlock Text="• 学号：您的校园网登录账号" TextWrapping="Wrap"/>
                        <TextBlock Text="• 密码：可选，保存后可自动登录" TextWrapping="Wrap"/>
                        <TextBlock Text="• Portal 地址：校园网门户地址，一般无需修改" TextWrapping="Wrap"/>
                        <TextBlock Text="• 自动登录：启用后连接校园网时自动登录" TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
