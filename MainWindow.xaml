<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AutoPortal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <muxc:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            Title="AutoPortal">
            <muxc:TitleBar.IconSource>
                <muxc:FontIconSource Glyph="&#xEC76;"/>
            </muxc:TitleBar.IconSource>
        </muxc:TitleBar>

        <muxc:NavigationView
            x:Name="NavigationView"
            Grid.Row="1"
            IsPaneToggleButtonVisible="True"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            IsPaneOpen="False"
            OpenPaneLength="200"
            CompactPaneLength="48"
            SelectionChanged="NavigationView_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="首页" Tag="Home">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE80F;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Content="登录" Tag="Login">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE77B;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem Content="设置" Tag="Settings">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE713;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>

            <muxc:Frame x:Name="ContentFrame"/>
        </muxc:NavigationView>
    </Grid>
</Window>
